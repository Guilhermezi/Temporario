generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id    Int    @id @default(autoincrement())
  nome  String @db.VarChar(255)
  email String @unique @db.VarChar(255)
  senha String @db.Text
  role  String @default("USER") @db.VarChar(50)

  @@map("usuarios")
}
