# OriginAuth — variáveis de ambiente

# Banco de dados PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/originauth"

# JWT (gere uma string aleatória longa e segura em produção)
JWT_SECRET="troque-isso-por-algo-secreto-em-producao"

# URL base da API (usada para gerar URLs de selos e compartilhamento)
BASE_URL="http://localhost:3000"

# URL do frontend (para CORS)
FRONTEND_URL="http://localhost:8080"

# Ambiente
NODE_ENV="development"

PORT=3000
